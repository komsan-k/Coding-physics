  {
    "id": "l111111111111111",
    "type": "function",
    "z": "f1a1b2c3d4e5f601",
    "name": "State Badge HTML",
    "func": "let s = msg.state || \"Unknown\";\nlet color = \"#999\";\nif (s === \"Dark\") color = \"#5e81ac\";\nelse if (s === \"Medium\") color = \"#e6b800\";\nelse if (s === \"Bright\") color = \"#ff7f0e\";\n\nmsg.payload = `<div style=\"padding:12px;text-align:center;\">\n  <span style=\"display:inline-block;padding:10px 18px;border-radius:18px;background:${color};color:white;font-size:20px;font-weight:bold;min-width:140px;\">\n    ${s}\n  </span>\n</div>`;\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
