  {
    "id": "e111111111111111",
    "type": "function",
    "z": "f1a1b2c3d4e5f601",
    "name": "Parse + Clamp + Compute",
    "func": "let x = Number(msg.payload);\nif (isNaN(x)) return null;\n\nx = Math.max(0, Math.min(4095, x));\nlet percent = (x / 4095) * 100;\nlet state = \"Dark\";\n\nif (x <= 1200) {\n    state = \"Dark\";\n} else if (x <= 2800) {\n    state = \"Medium\";\n} else {\n    state = \"Bright\";\n}\n\nmsg.payload = x;\nmsg.raw = x;\nmsg.percent = Number(percent.toFixed(1));\nmsg.state = state;\nmsg.topic = \"LDR\";\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 390,
    "y": 100,
    "wires": [
      [
        "g111111111111111",
        "h111111111111111",
        "i111111111111111",
        "j111111111111111",
        "k111111111111111",
        "l111111111111111"
      ]
    ]
